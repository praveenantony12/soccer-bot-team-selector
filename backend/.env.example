# WhatsApp Group JID (e.g. 12345678901234567890@g.us)
# You can find this by logging the group ID when a message arrives
WHATSAPP_GROUP_JID=your-group-jid@g.us

# Twilio Configuration
TWILIO_SID=your-twilio-sid
TWILIO_AUTH=your-twilio-auth-token
TWILIO_NUMBER=your-twilio-phone-number

# Frontend URL (when deployed)
BASE_URL=https://your-app-name.onrender.com

# Server Configuration
PORT=3000
NODE_ENV=development

# Timezone for cron jobs (e.g. Europe/London, America/New_York, Asia/Kolkata)
TZ=Europe/London

# Log level: trace | debug | info | warn | error
LOG_LEVEL=info
